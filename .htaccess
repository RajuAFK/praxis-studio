# Force HTTPS (works whether or not the host terminates TLS upstream)
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonical host — 301 praxis.photo (and any www. variant) to praxivision.com
RewriteCond %{HTTP_HOST} ^(www\.)?praxis\.photo$ [NC]
RewriteRule ^ https://praxivision.com%{REQUEST_URI} [L,R=301]

# Strip www. on the canonical host
RewriteCond %{HTTP_HOST} ^www\.praxivision\.com$ [NC]
RewriteRule ^ https://praxivision.com%{REQUEST_URI} [L,R=301]

# Map clean URLs to their .html files (Next static export)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Long-cache fingerprinted assets
<FilesMatch "\.(?:js|css|woff2?|ttf|otf|eot|jpg|jpeg|png|webp|avif|gif|svg|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Short-cache HTML so updates show up fast
<FilesMatch "\.html$">
  Header set Cache-Control "public, max-age=300, must-revalidate"
</FilesMatch>

ErrorDocument 404 /404.html
