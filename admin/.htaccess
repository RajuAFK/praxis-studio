# Force HTTPS for the admin
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block direct access to anything except the front controller, static assets,
# and the auth handler. Everything routes through index.php.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [L]

# Hard-deny config + lib + views + lockout — these are PHP includes, never URLs.
<FilesMatch "(config\.php|config\.example\.php)$">
  Require all denied
</FilesMatch>

RedirectMatch 404 /admin/lib/.*
RedirectMatch 404 /admin/views/.*
RedirectMatch 404 /admin/\.lockout.*

# No caching of admin pages
<IfModule mod_headers.c>
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header set Pragma "no-cache"
  Header set X-Frame-Options "DENY"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "same-origin"
</IfModule>

# No directory listing
Options -Indexes
